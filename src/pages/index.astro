---
// Shiva & Shloshim Calculator
---

<html lang="he" dir="rtl" data-lang="he">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>מתי קמים?</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;700&family=Frank+Ruhl+Libre:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>

<div class="container">
  <button id="lang-toggle" class="lang-toggle" type="button">EN</button>

  <h1 id="title">מתי קמים?</h1>
  <p id="subtitle" class="subtitle">הזן את תאריך הפטירה והקבורה כדי לחשב מתי נגמרים השבעה והשלושים</p>

  <!-- Israel/Diaspora banner -->
  <div class="location-banner">
    <span id="location-statement">חישוב לפי</span>
    <div class="toggle-group">
      <button type="button" class="toggle-btn active" id="toggle-israel" data-value="israel">ארץ ישראל</button>
      <button type="button" class="toggle-btn" id="toggle-diaspora" data-value="diaspora">חו״ל</button>
    </div>
  </div>

  <form id="calc-form" autocomplete="off">
    <!-- Date of passing -->
    <div class="field">
      <label id="label-death-date">תאריך הפטירה</label>
      <input type="hidden" id="death-date" />
      <button type="button" class="date-picker-trigger" data-target="death-date">
        <span class="date-picker-display" id="death-date-display">בחר תאריך...</span>
      </button>
      <span id="death-date-hint" class="field-hint">השאר ריק אם זהה לתאריך הקבורה</span>
    </div>

    <!-- Burial date -->
    <div class="field">
      <label id="label-date">תאריך הקבורה</label>
      <input type="hidden" id="burial-date" />
      <button type="button" class="date-picker-trigger" data-target="burial-date">
        <span class="date-picker-display" id="burial-date-display">בחר תאריך...</span>
      </button>
    </div>

    <!-- Unified calendar picker modal -->
    <div id="cal-overlay" class="heb-cal-overlay" style="display:none;">
      <div class="heb-cal-modal">
        <!-- Tabs -->
        <div class="cal-tabs">
          <button type="button" class="cal-tab active" id="tab-jewish">עברי</button>
          <button type="button" class="cal-tab" id="tab-civil">לועזי</button>
        </div>
        <div class="heb-cal-header">
          <button type="button" id="heb-cal-prev" class="heb-cal-nav">‹</button>
          <div class="heb-cal-selects" id="cal-selects-jewish">
            <select id="heb-cal-month"></select>
            <select id="heb-cal-year"></select>
          </div>
          <div class="heb-cal-selects" id="cal-selects-civil" style="display:none;">
            <select id="civil-cal-month"></select>
            <select id="civil-cal-year"></select>
          </div>
          <button type="button" id="heb-cal-next" class="heb-cal-nav">›</button>
        </div>
        <div class="heb-cal-weekdays" id="heb-cal-weekdays"></div>
        <div class="heb-cal-grid" id="heb-cal-grid"></div>
        <div class="heb-cal-legend">
          <span class="legend-item"><span class="legend-dot yom-tov-dot"></span><span class="legend-text" id="legend-yomtov">יו״ט</span></span>
          <span class="legend-item"><span class="legend-dot chol-hamoed-dot"></span><span class="legend-text" id="legend-cholhamoed">חוה״מ</span></span>
          <span class="legend-item"><span class="legend-dot shabat-dot"></span><span class="legend-text" id="legend-shabat">שבת</span></span>
        </div>
        <div class="heb-cal-footer">
          <button type="button" id="heb-cal-today" class="heb-cal-today-btn">היום</button>
          <button type="button" id="heb-cal-close" class="heb-cal-close-btn">סגור</button>
        </div>
      </div>
    </div>

    <!-- After nightfall -->
    <div class="field">
      <label class="checkbox-label">
        <input type="checkbox" id="after-nightfall" />
        <span id="label-after-nightfall">הקבורה היתה אחרי צאת הכוכבים</span>
      </label>
      <span id="after-nightfall-hint" class="field-hint">קבורה בבין השמשות (בין שקיעה לצאת הכוכבים) עדיין נחשבת לאותו יום. רק אחרי צאת הכוכבים היום ההלכתי הראשון הוא למחרת.</span>
      <a id="zmanim-link" class="zmanim-link" href="https://www.chabad.org/calendar/zmanim_cdo/locationid/689/locationtype/1/jewish/Halachic-Times.htm" target="_blank" rel="noopener">לא בטוח? בדוק זמנים ב-Chabad.org</a>
    </div>


    <button type="submit" id="calc-btn" class="btn-primary">
      <span id="calc-btn-text">חשב</span>
    </button>
  </form>

  <!-- Results -->
  <div id="results" class="results" style="display:none;">
    <h2 id="results-title">תוצאות</h2>

    <!-- Holiday notice -->
    <div id="holiday-notice" class="holiday-notice" style="display:none;"></div>

    <div class="result-card shiva-card">
      <div class="result-header">
        <h3 id="shiva-label">שבעה</h3>
        <span class="badge shiva-badge" id="shiva-badge"></span>
      </div>
      <div class="result-body">
        <div class="result-line">
          <span id="shiva-start-label" class="result-key">תחילה:</span>
          <div class="result-dates">
            <span id="shiva-start-heb" class="result-value highlight"></span>
            <span id="shiva-start-value" class="result-greg-date"></span>
          </div>
        </div>
        <div class="result-line">
          <span id="shiva-end-label" class="result-key">סיום:</span>
          <div class="result-dates">
            <span id="shiva-end-heb" class="result-value highlight"></span>
            <span id="shiva-end-value" class="result-greg-date"></span>
          </div>
        </div>
        <div id="shiva-cancelled-notice" class="cancelled-notice" style="display:none;"></div>
        <p id="shiva-note" class="result-note"></p>
      </div>
    </div>

    <div class="result-card shloshim-card">
      <div class="result-header">
        <h3 id="shloshim-label">שלושים</h3>
        <span class="badge shloshim-badge" id="shloshim-badge"></span>
      </div>
      <div class="result-body">
        <div class="result-line">
          <span id="shloshim-start-label" class="result-key">תחילה:</span>
          <div class="result-dates">
            <span id="shloshim-start-heb" class="result-value highlight"></span>
            <span id="shloshim-start-value" class="result-greg-date"></span>
          </div>
        </div>
        <div class="result-line">
          <span id="shloshim-end-label" class="result-key">סיום:</span>
          <div class="result-dates">
            <span id="shloshim-end-heb" class="result-value highlight"></span>
            <span id="shloshim-end-value" class="result-greg-date"></span>
          </div>
        </div>
        <div id="shloshim-cancelled-notice" class="cancelled-notice" style="display:none;"></div>
        <p id="shloshim-note" class="result-note"></p>
      </div>
    </div>

    <!-- Kaddish -->
    <div class="result-card kaddish-card">
      <div class="result-header">
        <h3 id="kaddish-label">קדיש</h3>
        <span class="badge kaddish-badge" id="kaddish-badge">11 חודשים</span>
      </div>
      <div class="result-body">
        <div class="result-line">
          <span id="kaddish-end-label" class="result-key">סיום:</span>
          <div class="result-dates">
            <span id="kaddish-end-heb" class="result-value highlight"></span>
            <span id="kaddish-end-value" class="result-greg-date"></span>
          </div>
        </div>
        <p id="kaddish-note" class="result-note">קדיש נאמר למשך 11 חודש מיום הפטירה</p>
      </div>
    </div>

    <!-- Yahrzeit -->
    <div class="result-card yahrzeit-card">
      <div class="result-header">
        <h3 id="yahrzeit-label">יארצייט</h3>
      </div>
      <div class="result-body">
        <div class="result-line">
          <span id="yahrzeit-heb-date-label" class="result-key">תאריך עברי:</span>
          <span id="yahrzeit-heb-date-value" class="result-value highlight"></span>
        </div>
        <div class="result-line">
          <span id="yahrzeit-first-label" class="result-key">יארצייט ראשון:</span>
          <div class="result-dates">
            <span id="yahrzeit-first-heb" class="result-value highlight"></span>
            <span id="yahrzeit-first-value" class="result-greg-date"></span>
          </div>
        </div>
        <div class="result-line">
          <span id="yahrzeit-second-label" class="result-key">יארצייט שני:</span>
          <div class="result-dates">
            <span id="yahrzeit-second-heb" class="result-value highlight"></span>
            <span id="yahrzeit-second-value" class="result-greg-date"></span>
          </div>
        </div>
        <p id="yahrzeit-note" class="result-note"></p>
      </div>
    </div>

    <p id="disclaimer" class="disclaimer"></p>
  </div>
</div>

<script>
  import {
    getJewishMonth,
    getJewishMonths,
    getJewishYears,
    getGregDate,
    getJewishDate,
    getPrevMonth,
    getNextMonth,
    getHebWeekdays,
    getEngWeekdays,
    getHolidays,
  } from 'jewish-dates-core';
  import { formatJewishDateInHebrew, formatJewishDate, JewishMonth, toGregorianDate, toJewishDate, getJewishMonthsInOrder } from 'jewish-date';

  // =====================
  // Unified Calendar Picker (Jewish + Civil tabs)
  // =====================
  let calTarget: string | null = null;
  let calMode: 'jewish' | 'civil' = 'jewish'; // default tab

  // Jewish calendar state
  let jewishState = { year: 0, month: '' as string };
  // Civil calendar state
  let civilState = { year: 0, month: 0 }; // month is 0-based

  const civilMonthsHe = ['ינואר','פברואר','מרץ','אפריל','מאי','יוני','יולי','אוגוסט','ספטמבר','אוקטובר','נובמבר','דצמבר'];
  const civilMonthsEn = ['January','February','March','April','May','June','July','August','September','October','November','December'];

  function initCal(targetDate?: Date) {
    const d = targetDate || new Date();
    const jd = getJewishDate(d);
    jewishState.year = jd.year;
    jewishState.month = jd.monthName;
    civilState.year = d.getFullYear();
    civilState.month = d.getMonth();
  }

  function setCalTab(mode: 'jewish' | 'civil') {
    calMode = mode;
    document.getElementById('tab-jewish')!.classList.toggle('active', mode === 'jewish');
    document.getElementById('tab-civil')!.classList.toggle('active', mode === 'civil');
    document.getElementById('cal-selects-jewish')!.style.display = mode === 'jewish' ? '' : 'none';
    document.getElementById('cal-selects-civil')!.style.display = mode === 'civil' ? '' : 'none';
    renderCal();
  }

  // Holiday lookup (shared between both views)
  function getHolidayData() {
    const yomTovSet = new Set(getHolidays(isIsrael));
    const cholHamoedDates: string[] = [];
    // Pesach: Israel 16-20 Nisan is Chol HaMoed, Diaspora 17-20
    const pesachStart = isIsrael ? 16 : 17;
    for (let d = pesachStart; d <= 20; d++) cholHamoedDates.push(`${d} Nisan`);
    // Sukkot: Israel 16-21 Tishri is Chol HaMoed, Diaspora 17-21
    const sukkotStart = isIsrael ? 16 : 17;
    for (let d = sukkotStart; d <= 21; d++) cholHamoedDates.push(`${d} Tishri`);
    return { yomTovSet, cholHamoedSet: new Set(cholHamoedDates) };
  }

  function renderCal() {
    if (calMode === 'jewish') renderJewishCal();
    else renderCivilCal();
  }

  function renderJewishCal() {
    const isHeb = currentLang === 'he';
    const monthSelect = document.getElementById('heb-cal-month') as HTMLSelectElement;
    const yearSelect = document.getElementById('heb-cal-year') as HTMLSelectElement;
    const grid = document.getElementById('heb-cal-grid')!;
    const weekdaysEl = document.getElementById('heb-cal-weekdays')!;

    const months = getJewishMonths(jewishState.year, isHeb);
    monthSelect.innerHTML = months.map(m =>
      `<option value="${m.id}" ${m.id === jewishState.month ? 'selected' : ''}>${m.text}</option>`
    ).join('');

    const currentJewishYear = getJewishDate(new Date()).year;
    const years = getJewishYears(jewishState.year).filter(y => y >= 5700 && y <= currentJewishYear);
    yearSelect.innerHTML = years.map(y =>
      `<option value="${y}" ${y === jewishState.year ? 'selected' : ''}>${y}</option>`
    ).join('');

    const gregDate = getGregDate({
      day: 1,
      monthName: JewishMonth[jewishState.month as keyof typeof JewishMonth],
      year: jewishState.year,
    });
    const calData = getJewishMonth(gregDate);
    const weekdays = isHeb ? getHebWeekdays() : getEngWeekdays();
    weekdaysEl.innerHTML = weekdays.map(w => `<span class="heb-cal-wd">${w}</span>`).join('');

    const { yomTovSet, cholHamoedSet } = getHolidayData();

    const todayStr = new Date().toISOString().split('T')[0];

    grid.innerHTML = calData.days.map(day => {
      const dateStr = day.dayjsDate.format('YYYY-MM-DD');
      const hebStr = formatJewishDateInHebrew(day.jewishDate);
      const dayNum = hebStr.split(' ')[0];
      const classes = ['heb-cal-day'];
      if (!day.isCurrentMonth) classes.push('other-month');
      if (dateStr === todayStr) classes.push('today');

      const jewishKey = `${day.jewishDate.day} ${day.jewishDate.monthName}`;
      if (day.isCurrentMonth) {
        if (yomTovSet.has(jewishKey)) classes.push('yom-tov');
        else if (cholHamoedSet.has(jewishKey)) classes.push('chol-hamoed');
        if (day.date.getDay() === 6) classes.push('shabat');
      }

      const tooltip = isHeb ? hebStr : day.jewishDateStr;
      return `<button type="button" class="${classes.join(' ')}" data-date="${dateStr}" title="${tooltip}">${isHeb ? dayNum : day.jewishDate.day}</button>`;
    }).join('');

    // Sync civil state from jewish view
    civilState.year = gregDate.getFullYear();
    civilState.month = gregDate.getMonth();
  }

  function renderCivilCal() {
    const isHeb = currentLang === 'he';
    const monthSelect = document.getElementById('civil-cal-month') as HTMLSelectElement;
    const yearSelect = document.getElementById('civil-cal-year') as HTMLSelectElement;
    const grid = document.getElementById('heb-cal-grid')!;
    const weekdaysEl = document.getElementById('heb-cal-weekdays')!;

    const monthNames = isHeb ? civilMonthsHe : civilMonthsEn;
    monthSelect.innerHTML = monthNames.map((name, i) =>
      `<option value="${i}" ${i === civilState.month ? 'selected' : ''}>${name}</option>`
    ).join('');

    const baseYear = civilState.year;
    const yearOptions: number[] = [];
    const currentCivilYear = new Date().getFullYear();
    for (let y = 1940; y <= currentCivilYear; y++) yearOptions.push(y);
    yearSelect.innerHTML = yearOptions.map(y =>
      `<option value="${y}" ${y === civilState.year ? 'selected' : ''}>${y}</option>`
    ).join('');

    const weekdays = isHeb ? getHebWeekdays() : getEngWeekdays();
    weekdaysEl.innerHTML = weekdays.map(w => `<span class="heb-cal-wd">${w}</span>`).join('');

    // Build civil calendar grid
    const firstOfMonth = new Date(civilState.year, civilState.month, 1);
    const startDay = firstOfMonth.getDay(); // 0=Sun
    const daysInMonth = new Date(civilState.year, civilState.month + 1, 0).getDate();
    const prevMonthDays = new Date(civilState.year, civilState.month, 0).getDate();

    const { yomTovSet, cholHamoedSet } = getHolidayData();
    const todayStr = new Date().toISOString().split('T')[0];
    let cells = '';

    // Previous month padding
    for (let i = startDay - 1; i >= 0; i--) {
      const day = prevMonthDays - i;
      const d = new Date(civilState.year, civilState.month - 1, day);
      const dateStr = d.toISOString().split('T')[0];
      cells += `<button type="button" class="heb-cal-day other-month" data-date="${dateStr}">${day}</button>`;
    }

    // Current month days
    for (let day = 1; day <= daysInMonth; day++) {
      const d = new Date(civilState.year, civilState.month, day);
      const dateStr = `${civilState.year}-${String(civilState.month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const jd = getJewishDate(d);
      const jewishKey = `${jd.day} ${jd.monthName}`;
      const hebStr = formatJewishDateInHebrew(jd);

      const classes = ['heb-cal-day'];
      if (dateStr === todayStr) classes.push('today');
      if (yomTovSet.has(jewishKey)) classes.push('yom-tov');
      else if (cholHamoedSet.has(jewishKey)) classes.push('chol-hamoed');
      if (d.getDay() === 6) classes.push('shabat');

      const tooltip = `${day} ${monthNames[civilState.month]} — ${hebStr}`;
      cells += `<button type="button" class="${classes.join(' ')}" data-date="${dateStr}" title="${tooltip}">${day}</button>`;
    }

    // Next month padding
    const totalCells = startDay + daysInMonth;
    const remaining = totalCells <= 35 ? 35 - totalCells : 42 - totalCells;
    for (let day = 1; day <= remaining; day++) {
      const d = new Date(civilState.year, civilState.month + 1, day);
      const dateStr = d.toISOString().split('T')[0];
      cells += `<button type="button" class="heb-cal-day other-month" data-date="${dateStr}">${day}</button>`;
    }

    grid.innerHTML = cells;

    // Sync jewish state
    const jdFirst = getJewishDate(firstOfMonth);
    jewishState.year = jdFirst.year;
    jewishState.month = jdFirst.monthName;
  }

  function updateDateDisplay(inputId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement;
    const display = document.getElementById(inputId + '-display')!;
    if (!input.value) {
      const t = translations[currentLang];
      display.textContent = currentLang === 'he' ? 'בחר תאריך...' : 'Select date...';
      display.classList.add('placeholder');
      return;
    }
    const d = new Date(input.value + 'T12:00:00');
    const jd = getJewishDate(d);
    const hebStr = currentLang === 'he' ? formatJewishDateInHebrew(jd) : formatJewishDate(jd);
    const gregStr = formatDate(input.value, currentLang);
    display.textContent = `${hebStr}  •  ${gregStr}`;
    display.classList.remove('placeholder');
  }

  function openCal(targetId: string) {
    calTarget = targetId;
    const input = document.getElementById(targetId) as HTMLInputElement;
    const targetDate = input.value ? new Date(input.value + 'T12:00:00') : new Date();
    initCal(targetDate);
    setCalTab('jewish'); // always open on Jewish tab
    document.getElementById('cal-overlay')!.style.display = '';
  }

  function closeCal() {
    document.getElementById('cal-overlay')!.style.display = 'none';
    calTarget = null;
  }

  function selectCalDate(dateStr: string) {
    if (!calTarget) return;
    const input = document.getElementById(calTarget) as HTMLInputElement;
    input.value = dateStr;
    input.dispatchEvent(new Event('change', { bubbles: true }));
    updateDateDisplay(calTarget);
    closeCal();
  }

  // Event delegation
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Open calendar
    if (target.closest('.date-picker-trigger')) {
      const btn = target.closest('.date-picker-trigger') as HTMLElement;
      openCal(btn.dataset.target!);
      return;
    }

    // Day selection
    if (target.classList.contains('heb-cal-day') && !target.classList.contains('other-month')) {
      selectCalDate(target.dataset.date!);
      return;
    }

    // Close on overlay click
    if (target.id === 'cal-overlay') {
      closeCal();
      return;
    }
  });

  // Tab switching
  document.getElementById('tab-jewish')?.addEventListener('click', () => setCalTab('jewish'));
  document.getElementById('tab-civil')?.addEventListener('click', () => setCalTab('civil'));

  // Nav buttons
  document.getElementById('heb-cal-prev')?.addEventListener('click', () => {
    if (calMode === 'jewish') {
      const prev = getPrevMonth({
        year: jewishState.year,
        month: JewishMonth[jewishState.month as keyof typeof JewishMonth],
        isHebrew: currentLang === 'he',
      });
      jewishState.year = prev.year;
      jewishState.month = JewishMonth[prev.month as keyof typeof JewishMonth] || prev.month;
      if (typeof prev.month === 'number') {
        jewishState.month = Object.keys(JewishMonth).find(k => JewishMonth[k as keyof typeof JewishMonth] === prev.month) || jewishState.month;
      }
    } else {
      civilState.month--;
      if (civilState.month < 0) { civilState.month = 11; civilState.year--; }
    }
    renderCal();
  });

  document.getElementById('heb-cal-next')?.addEventListener('click', () => {
    if (calMode === 'jewish') {
      const next = getNextMonth({
        year: jewishState.year,
        month: JewishMonth[jewishState.month as keyof typeof JewishMonth],
        isHebrew: currentLang === 'he',
      });
      jewishState.year = next.year;
      jewishState.month = JewishMonth[next.month as keyof typeof JewishMonth] || next.month;
      if (typeof next.month === 'number') {
        jewishState.month = Object.keys(JewishMonth).find(k => JewishMonth[k as keyof typeof JewishMonth] === next.month) || jewishState.month;
      }
    } else {
      civilState.month++;
      if (civilState.month > 11) { civilState.month = 0; civilState.year++; }
    }
    renderCal();
  });

  // Month/Year selects (Jewish)
  document.getElementById('heb-cal-month')?.addEventListener('change', (e) => {
    jewishState.month = (e.target as HTMLSelectElement).value;
    renderCal();
  });
  document.getElementById('heb-cal-year')?.addEventListener('change', (e) => {
    jewishState.year = parseInt((e.target as HTMLSelectElement).value);
    renderCal();
  });

  // Month/Year selects (Civil)
  document.getElementById('civil-cal-month')?.addEventListener('change', (e) => {
    civilState.month = parseInt((e.target as HTMLSelectElement).value);
    renderCal();
  });
  document.getElementById('civil-cal-year')?.addEventListener('change', (e) => {
    civilState.year = parseInt((e.target as HTMLSelectElement).value);
    renderCal();
  });

  // Today button
  document.getElementById('heb-cal-today')?.addEventListener('click', () => {
    const today = new Date();
    const dateStr = today.toISOString().split('T')[0];
    selectCalDate(dateStr);
  });

  // Close button
  document.getElementById('heb-cal-close')?.addEventListener('click', closeCal);

  // =====================
  // Types
  // =====================
  interface HolidayPeriod {
    id: string;
    nameHe: string;
    nameEn: string;
    erev: string;        // day before first yom tov (holiday starts at sunset)
    firstDay: string;
    lastDay: string;     // last day of entire period including chol hamoed
    yomTovDays: string[];
    cholHamoedDays: string[];
    // How many "equivalent days" this holiday counts toward shloshim when it cancels shiva
    shloshimEquivalent: number;
  }

