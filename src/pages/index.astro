  // =====================
  // Date helpers
  // =====================
  function addDays(dateStr: string, days: number): string {
    const d = new Date(dateStr + 'T12:00:00');
    d.setDate(d.getDate() + days);
    return d.toISOString().split('T')[0];
  }

  function daysBetween(a: string, b: string): number {
    const da = new Date(a + 'T12:00:00');
    const db = new Date(b + 'T12:00:00');
    return Math.round((db.getTime() - da.getTime()) / 86400000);
  }

  function formatDate(dateStr: string, lang: string): string {
    const d = new Date(dateStr + 'T12:00:00');
    return d.toLocaleDateString(lang === 'he' ? 'he-IL' : 'en-US', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
    });
  }

  // =====================
  // =====================
  // Kaddish & Yahrzeit helpers
  // =====================

  /**
   * Calculate when Kaddish ends: 11 Hebrew months from date of passing.
   * Returns the Gregorian date string.
   */
  function calcKaddishEnd(deathDateStr: string): { gregDate: string; jewishDate: any } {
    const d = new Date(deathDateStr + 'T12:00:00');
    const jd = toJewishDate(d);
    const monthsInOrder = getJewishMonthsInOrder(jd.year);

    let targetYear = jd.year;
    let targetMonthName = jd.monthName;
    let monthsToAdd = 11;

    // Walk forward 11 months in the Hebrew calendar
    const currentMonthsOrder = getJewishMonthsInOrder(targetYear);
    let idx = currentMonthsOrder.indexOf(jd.monthName);

    while (monthsToAdd > 0) {
      idx++;
      const yearMonths = getJewishMonthsInOrder(targetYear);
      if (idx >= yearMonths.length) {
        targetYear++;
        idx = 1; // Skip JewishMonth.None at index 0
      }
      const newMonths = getJewishMonthsInOrder(targetYear);
      targetMonthName = newMonths[idx];
      monthsToAdd--;
    }

    // Use the same day, clamped to month length
    let targetDay = jd.day;
    // Try to create the date; if day is too high, the library will handle it
    const targetJd = { day: targetDay, monthName: targetMonthName, year: targetYear };
    const greg = toGregorianDate(targetJd);

    return {
      gregDate: greg.toISOString().split('T')[0],
      jewishDate: targetJd,
    };
  }

  /**
   * Calculate yahrzeit: the Hebrew date of death in future years.
   * Returns Gregorian date for the given Hebrew year.
   */
  function calcYahrzeit(deathDateStr: string, yearOffset: number): { gregDate: string; jewishDate: any } {
    const d = new Date(deathDateStr + 'T12:00:00');
    const jd = toJewishDate(d);

    const targetYear = jd.year + yearOffset;
    let targetMonthName = jd.monthName;

    // Handle Adar in leap/non-leap year transitions
    const targetMonths = getJewishMonthsInOrder(targetYear);
    const hasAdarI = targetMonths.includes(JewishMonth.AdarI);
    const hasAdarII = targetMonths.includes(JewishMonth.AdarII);
    const sourceMonths = getJewishMonthsInOrder(jd.year);
    const sourceHasAdarI = sourceMonths.includes(JewishMonth.AdarI);

    if (jd.monthName === JewishMonth.AdarI && !hasAdarI) {
      // Death in Adar I of leap year, target is non-leap: use Adar
      targetMonthName = JewishMonth.Adar;
    } else if (jd.monthName === JewishMonth.AdarII && !hasAdarII) {
      // Death in Adar II of leap year, target is non-leap: use Adar
      targetMonthName = JewishMonth.Adar;
    } else if (jd.monthName === JewishMonth.Adar && hasAdarII) {
      // Death in Adar of non-leap year, target is leap: use Adar II
      targetMonthName = JewishMonth.AdarII;
    }

    const targetJd = { day: jd.day, monthName: targetMonthName, year: targetYear };
    const greg = toGregorianDate(targetJd);

    return {
      gregDate: greg.toISOString().split('T')[0],
      jewishDate: targetJd,
    };
  }

  // HebCal API helpers
  // =====================
  async function fetchHolidays(startDate: string, endDate: string, israel: boolean): Promise<any[]> {
    try {
      const i = israel ? 'on' : 'off';
      const url = `https://www.hebcal.com/hebcal?v=1&cfg=json&maj=on&min=off&mod=off&nx=off&ss=off&mf=off&c=off&i=${i}&start=${startDate}&end=${endDate}`;
      const resp = await fetch(url);
      const data = await resp.json();
      return data.items || [];
    } catch { return []; }
  }

  // =====================
  // Holiday grouping
  // =====================
  function groupHolidays(items: any[], israel: boolean): HolidayPeriod[] {
    const groups: Record<string, { yomTov: string[]; cholHamoed: string[]; all: string[] }> = {};

    for (const item of items) {
      const title: string = item.title || '';
      const date: string = item.date;
      const isYomTov = item.yomtov === true;

      let groupId: string | null = null;

      if (title.includes('Pesach')) {
        groupId = 'pesach';
      } else if (title.includes('Shavuot')) {
        groupId = 'shavuot';
      } else if (title.includes('Sukkot')) {
        groupId = 'sukkot';
      } else if (title.includes('Shmini Atzeret') || title.includes('Simchat Torah')) {
        groupId = 'shmini-atzeret';
      } else if (title.includes('Rosh Hashana')) {
        groupId = 'rosh-hashana';
      } else if (title.includes('Yom Kippur')) {
        groupId = 'yom-kippur';
      }

      if (!groupId) continue;
      // Skip erev entries for grouping purposes
      if (title.startsWith('Erev ')) continue;

      if (!groups[groupId]) {
        groups[groupId] = { yomTov: [], cholHamoed: [], all: [] };
      }
      groups[groupId].all.push(date);
      if (isYomTov) {
        groups[groupId].yomTov.push(date);
      } else {
        groups[groupId].cholHamoed.push(date);
      }
    }

    const periods: HolidayPeriod[] = [];

    for (const [id, g] of Object.entries(groups)) {
      if (g.all.length === 0) continue;
      g.all.sort();
      g.yomTov.sort();
      g.cholHamoed.sort();

      const firstDay = g.all[0];
      const lastDay = g.all[g.all.length - 1];
      const erev = addDays(firstDay, -1);

      // Shloshim equivalents when this holiday cancels shiva
      let equiv = 0;
      if (id === 'pesach') {
        equiv = israel ? 7 : 8;
      } else if (id === 'shavuot') {
        // First day of Shavuot = 7 equivalent days; second day (diaspora) = 1 more
        equiv = israel ? 7 : 8;
      } else if (id === 'sukkot') {
        equiv = 7; // Just Sukkot proper (7 days); Shmini Atzeret is separate
      } else if (id === 'shmini-atzeret') {
        // Shmini Atzeret = 7 equivalent days; Simchat Torah (diaspora) = 1 more
        equiv = israel ? 7 : 8;
      } else if (id === 'rosh-hashana') {
        equiv = 2;
      } else if (id === 'yom-kippur') {
        equiv = 1;
      }

      const names = holidayNames[id] || { he: id, en: id };
      periods.push({
        id,
        nameHe: names.he,
        nameEn: names.en,
        erev,
        firstDay,
        lastDay,
        yomTovDays: g.yomTov,
        cholHamoedDays: g.cholHamoed,
        shloshimEquivalent: equiv,
      });
    }

    // Sort by first day
    periods.sort((a, b) => a.firstDay.localeCompare(b.firstDay));
    return periods;
  }

  // Check if a date falls within a holiday period (yom tov or chol hamoed)
  function findHolidayAtDate(date: string, holidays: HolidayPeriod[]): HolidayPeriod | null {
    for (const h of holidays) {
      if (date >= h.firstDay && date <= h.lastDay) return h;
    }
    return null;
  }

  // =====================
  // Main mourning calculation
  // =====================
  function calculateMourning(
    deathDate: string,
    burialDate: string,
    afterNightfall: boolean,
    holidays: HolidayPeriod[],
  ): MourningResult {
    const notes: string[] = [];

    // Effective burial date (halachic day)
    let effectiveBurial = afterNightfall ? addDays(burialDate, 1) : burialDate;

    // Check if burial occurred during a holiday/chol hamoed
    const holidayAtBurial = findHolidayAtDate(effectiveBurial, holidays);
    let day1: string;
    let shivaDelayed = false;
    let shivaDelayedUntilAfter: string | null = null;

    if (holidayAtBurial) {
      // Shiva begins after the holiday concludes
      // The last day of the festival counts as day 1
      day1 = holidayAtBurial.lastDay;
      shivaDelayed = true;
      shivaDelayedUntilAfter = holidayAtBurial.id;

      const name = currentLang === 'he' ? holidayAtBurial.nameHe : holidayAtBurial.nameEn;
      if (currentLang === 'he') {
        notes.push(`הקבורה חלה בתוך ${name}. השבעה מתחילה ביום האחרון של החג.`);
      } else {
        notes.push(`Burial occurred during ${name}. Shiva begins on the last day of the holiday.`);
      }

      // But the holiday days still count toward shloshim
      // Shloshim counting starts from the burial date even if shiva is delayed
    } else {
      day1 = effectiveBurial;
    }

    // Also check if death occurred during a holiday but burial after
    // (If death was during holiday and mourner didn't know, shiva starts after holiday)
    if (!holidayAtBurial && deathDate !== burialDate) {
      const holidayAtDeath = findHolidayAtDate(deathDate, holidays);
      if (holidayAtDeath && effectiveBurial > holidayAtDeath.lastDay) {
        // Death was during holiday, burial after — shiva starts from burial as normal
        // No special handling needed, but note it
      }
    }

    // Naive end dates
    let shivaEnd = addDays(day1, 6);
    let shloshimEnd: string;

    // For shloshim, counting starts from burial date (or effective burial) even if shiva was delayed
    if (shivaDelayed && holidayAtBurial) {
      // Holiday days count toward shloshim even though shiva hasn't started
      shloshimEnd = addDays(effectiveBurial, 29);
    } else {
      shloshimEnd = addDays(day1, 29);
    }

    let shivaCancelled = false;
    let shivaCancelledBy: string | null = null;
    let shloshimCancelled = false;
    let shloshimCancelledBy: string | null = null;

    // Process holidays chronologically for cancellation
    for (const holiday of holidays) {
      // Skip the holiday that delayed shiva (already handled)
      if (shivaDelayed && holiday.id === holidayAtBurial?.id) continue;

      const holidayStart = holiday.erev; // Holiday begins at sunset of erev

      // Did mourning begin before this holiday?
      if (day1 <= holidayStart) {
        if (!shivaCancelled && holidayStart < shivaEnd) {
          // Holiday cancels remaining shiva
          shivaCancelled = true;
          shivaCancelledBy = holiday.id;
          shivaEnd = holidayStart; // Shiva ends at onset of holiday

          const name = currentLang === 'he' ? holiday.nameHe : holiday.nameEn;
          if (currentLang === 'he') {
            notes.push(`${name} מבטל את יתרת השבעה.`);
          } else {
            notes.push(`${name} cancels the remainder of shiva.`);
          }

          // Calculate shloshim with holiday equivalents
          const daysBeforeHoliday = daysBetween(day1, holidayStart);
          const totalEquiv = daysBeforeHoliday + holiday.shloshimEquivalent;

          if (totalEquiv >= 30) {
            shloshimEnd = holiday.lastDay;
            shloshimCancelled = true;
            shloshimCancelledBy = holiday.id;
            if (currentLang === 'he') {
              notes.push(`${name} מבטל גם את יתרת השלושים.`);
            } else {
              notes.push(`${name} also cancels the remainder of shloshim.`);
            }
          } else {
            const remaining = 30 - totalEquiv;
            shloshimEnd = addDays(holiday.lastDay, remaining);
          }
        } else if (shivaCancelled && !shloshimCancelled && holidayStart <= shloshimEnd) {
          // Shiva already done/cancelled; this holiday cancels remaining shloshim
          shloshimCancelled = true;
          shloshimCancelledBy = holiday.id;
          shloshimEnd = holidayStart;

          const name = currentLang === 'he' ? holiday.nameHe : holiday.nameEn;
          if (currentLang === 'he') {
            notes.push(`${name} מבטל את יתרת השלושים.`);
          } else {
            notes.push(`${name} cancels the remainder of shloshim.`);
          }
        } else if (!shivaCancelled && !shloshimCancelled && holidayStart >= shivaEnd && holidayStart <= shloshimEnd) {
          // Shiva completed normally before the holiday; holiday cancels shloshim
          shloshimCancelled = true;
          shloshimCancelledBy = holiday.id;
          shloshimEnd = holidayStart;

          const name = currentLang === 'he' ? holiday.nameHe : holiday.nameEn;
          if (currentLang === 'he') {
            notes.push(`השבעה הסתיימה לפני ${name}. ${name} מבטל את יתרת השלושים.`);
          } else {
            notes.push(`Shiva completed before ${name}. ${name} cancels the remainder of shloshim.`);
          }
        }
      }
    }

    return {
      day1,
      shivaEnd,
      shloshimEnd,
      shivaCancelled,
      shivaCancelledBy,
      shloshimCancelled,
      shloshimCancelledBy,
      shivaDelayed,
      shivaDelayedUntilAfter,
      notes,
    };
  }

  // =====================
  // Form submission
  // =====================
  document.getElementById('calc-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const t = translations[currentLang];

    const burialDate = (document.getElementById('burial-date') as HTMLInputElement).value;
    if (!burialDate) return;

    let deathDate = (document.getElementById('death-date') as HTMLInputElement).value;
    if (!deathDate) deathDate = burialDate;

    const afterNightfall = (document.getElementById('after-nightfall') as HTMLInputElement).checked;

    const calcBtn = document.getElementById('calc-btn') as HTMLButtonElement;
    calcBtn.disabled = true;
    document.getElementById('calc-btn-text')!.textContent = t['calculating'];

    // Fetch holidays for the relevant range (death date through burial + 60 days)
    const rangeStart = deathDate < burialDate ? deathDate : burialDate;
    const rangeEnd = addDays(burialDate, 60);
    const holidayItems = await fetchHolidays(rangeStart, rangeEnd, isIsrael);
    const holidays = groupHolidays(holidayItems, isIsrael);

    // Run calculation
    const result = calculateMourning(deathDate, burialDate, afterNightfall, holidays);

    // Display results with both Gregorian and Hebrew dates
    document.getElementById('shiva-start-value')!.textContent = formatDate(result.day1, currentLang);
    document.getElementById('shiva-end-value')!.textContent = formatDate(result.shivaEnd, currentLang);
    document.getElementById('shloshim-start-value')!.textContent = formatDate(result.day1, currentLang);
    document.getElementById('shloshim-end-value')!.textContent = formatDate(result.shloshimEnd, currentLang);

    // Hebrew dates with day of week
    const hebDayNames = ['יום ראשון', 'יום שני', 'יום שלישי', 'יום רביעי', 'יום חמישי', 'יום שישי', 'שבת'];
    const engDayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Shabbat'];
    const formatHeb = (dateStr: string) => {
      const d = new Date(dateStr + 'T12:00:00');
      const jd = getJewishDate(d);
      const dayName = currentLang === 'he' ? hebDayNames[d.getDay()] : engDayNames[d.getDay()];
      const hebDate = currentLang === 'he' ? formatJewishDateInHebrew(jd) : formatJewishDate(jd);
      return `${dayName}, ${hebDate}`;
    };
    document.getElementById('shiva-start-heb')!.textContent = formatHeb(result.day1);
    document.getElementById('shiva-end-heb')!.textContent = formatHeb(result.shivaEnd);
    document.getElementById('shloshim-start-heb')!.textContent = formatHeb(result.day1);
    document.getElementById('shloshim-end-heb')!.textContent = formatHeb(result.shloshimEnd);

    // Badges
    const shivaBadge = document.getElementById('shiva-badge')!;
    const shloshimBadge = document.getElementById('shloshim-badge')!;

    if (result.shivaCancelled) {
      const name = currentLang === 'he'
        ? holidayNames[result.shivaCancelledBy!]?.he
        : holidayNames[result.shivaCancelledBy!]?.en;
      shivaBadge.textContent = currentLang === 'he' ? `בוטל ע״י ${name}` : `Cancelled by ${name}`;
      shivaBadge.className = 'badge cancelled-badge';
    } else {
      const numDays = daysBetween(result.day1, result.shivaEnd) + 1;
      shivaBadge.textContent = `${numDays} ${t['days']}`;
      shivaBadge.className = 'badge shiva-badge';
    }

    if (result.shloshimCancelled) {
      const name = currentLang === 'he'
        ? holidayNames[result.shloshimCancelledBy!]?.he
        : holidayNames[result.shloshimCancelledBy!]?.en;
      shloshimBadge.textContent = currentLang === 'he' ? `בוטל ע״י ${name}` : `Cancelled by ${name}`;
      shloshimBadge.className = 'badge cancelled-badge';
    } else {
      shloshimBadge.textContent = `30 ${t['days']}`;
      shloshimBadge.className = 'badge shloshim-badge';
    }

    // Shiva note
    const shivaNote = document.getElementById('shiva-note')!;
    if (result.shivaCancelled) {
      shivaNote.textContent = currentLang === 'he'
        ? `השבעה הסתיימה בערב החג (${formatDate(result.shivaEnd, currentLang)})`
        : `Shiva ended at the onset of the holiday (${formatDate(result.shivaEnd, currentLang)})`;
    } else {
      shivaNote.textContent = t['shiva-normal-note'];
    }

    // Shloshim note
    const shloshimNote = document.getElementById('shloshim-note')!;
    if (result.shloshimCancelled) {
      shloshimNote.textContent = currentLang === 'he'
        ? `השלושים הסתיימו בערב החג (${formatDate(result.shloshimEnd, currentLang)})`
        : `Shloshim ended at the onset of the holiday (${formatDate(result.shloshimEnd, currentLang)})`;
    } else {
      shloshimNote.textContent = t['shloshim-normal-note'];
    }

    // Cancelled notices
    const shivaCancelledEl = document.getElementById('shiva-cancelled-notice')!;
    const shloshimCancelledEl = document.getElementById('shloshim-cancelled-notice')!;
    shivaCancelledEl.style.display = 'none';
    shloshimCancelledEl.style.display = 'none';

    // Holiday notice
    const holidayNotice = document.getElementById('holiday-notice')!;
    if (result.notes.length > 0) {
      holidayNotice.innerHTML = result.notes.map(n => `<p>${n}</p>`).join('');
      holidayNotice.style.display = '';
    } else {
      holidayNotice.style.display = 'none';
    }

    // Kaddish end (11 Hebrew months from death)
    const kaddishResult = calcKaddishEnd(deathDate);
    document.getElementById('kaddish-end-value')!.textContent = formatDate(kaddishResult.gregDate, currentLang);
    document.getElementById('kaddish-end-heb')!.textContent = formatHeb(kaddishResult.gregDate);

    // Yahrzeit (Hebrew date of death)
    const deathHebDate = getJewishDate(new Date(deathDate + 'T12:00:00'));
    const deathHebStr = currentLang === 'he'
      ? formatJewishDateInHebrew(deathHebDate)
      : formatJewishDate(deathHebDate);
    document.getElementById('yahrzeit-heb-date-value')!.textContent = deathHebStr;

    // First yahrzeit (1 year after death in Hebrew calendar)
    const firstYahrzeit = calcYahrzeit(deathDate, 1);
    document.getElementById('yahrzeit-first-value')!.textContent = formatDate(firstYahrzeit.gregDate, currentLang);
    document.getElementById('yahrzeit-first-heb')!.textContent = formatHeb(firstYahrzeit.gregDate);

    // Second yahrzeit (2 years after)
    const secondYahrzeit = calcYahrzeit(deathDate, 2);
    document.getElementById('yahrzeit-second-value')!.textContent = formatDate(secondYahrzeit.gregDate, currentLang);
    document.getElementById('yahrzeit-second-heb')!.textContent = formatHeb(secondYahrzeit.gregDate);

    // Yahrzeit note - show if Adar handling applies
    const yahrzeitNote = document.getElementById('yahrzeit-note')!;
    const deathMonthName = deathHebDate.monthName;
    if (deathMonthName === JewishMonth.AdarI || deathMonthName === JewishMonth.AdarII || deathMonthName === JewishMonth.Adar) {
      yahrzeitNote.textContent = currentLang === 'he'
        ? 'שימו לב: תאריך היארצייט עשוי להשתנות בשנים מעוברות/פשוטות. יש לבדוק לכל שנה.'
        : 'Note: Yahrzeit date may differ in leap/non-leap years. Verify for each year.';
    } else {
      yahrzeitNote.textContent = '';
    }

    // Show results
    document.getElementById('results')!.style.display = '';

    calcBtn.disabled = false;
    document.getElementById('calc-btn-text')!.textContent = t['calc-btn-text'];
    document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

<style is:global>
  *, *::before, *::after {
