  }

  /* Calendar tabs */
  .cal-tabs {
    display: flex;
    border-bottom: 2px solid #e0d8c8;
    margin-bottom: 0.75rem;
  }
  .cal-tab {
    flex: 1;
    font-family: 'Heebo', sans-serif;
