  .btn-primary:hover { background: #6d5a43; }
  .btn-primary:disabled { opacity: 0.7; cursor: wait; }

  /* Results */
  .results { margin-top: 2rem; }
  .results h2 {
    font-family: 'Frank Ruhl Libre', serif;
    font-size: 1.5rem;
    color: #4a3c2c;
