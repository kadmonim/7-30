  .heb-cal-modal {
    background: #faf9f6;
    border: 1px solid #d4c5a9;
    border-radius: 12px;
    padding: 1rem;
    width: 320px;
    max-width: 95vw;
    box-shadow: 0 8px 32px rgba(0,0,0,0.15);
  }

  .heb-cal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    gap: 0.5rem;
  }

  .heb-cal-nav {
    background: none;
    border: 1px solid #d4c5a9;
